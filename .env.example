# Copy this file to .env and adjust as needed:  cp .env.example .env

# Container / volume name
CONTAINER_NAME=pgvector_db

# Postgres credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vectordb

# Host port to expose Postgres on (container always listens on 5432)
POSTGRES_PORT=5432

# Name of the (external) Docker network to join, so your app's containers can
# reach this DB by its container name. Set this to your app's network.
# Create it once if it doesn't exist:  docker network create <NETWORK_NAME>
NETWORK_NAME=pgvector_net
